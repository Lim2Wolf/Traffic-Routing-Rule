DOMAIN,acctransfer.futuhn.com    # 转账
DOMAIN,authfthk.futuhn.com
DOMAIN,sdauth.futuhn.com
DOMAIN-SUFFIX,moomoo.com         # authority.sg.moomoo.com 等账户域
